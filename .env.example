# Copy this file to .env and fill in your real values. NEVER commit real secrets.

# --- Core bot ---
TELEGRAM_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx   # numeric id of your channel (bot must be admin)
NEWS_API_KEY=your-newsapi-key
GEMINI_API_KEY=your-gemini-api-key
PEXELS_API_KEY=your-pexels-key
UNSPLASH_ACCESS_KEY=your-unsplash-key

# --- Twitter / X ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- Reddit (script app from reddit.com/prefs/apps) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=AgenticNewsBot/1.0

# --- Instagram (Meta Graph API) ---
IG_USER_ID=
IG_ACCESS_TOKEN=

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
